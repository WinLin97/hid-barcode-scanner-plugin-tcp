<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Required so the core app's permission-protected scan broadcast reaches us,
         and so the core's discover() lists this plugin. -->
    <uses-permission android:name="dev.fabik.bluetoothhid.permission.RECEIVE_SCANS" />

    <!-- This plugin forwards scans over TCP -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Persistent TCP connection (server accept loop / client keep-alive) runs in a foreground
         service. Type specialUse, NOT dataSync: Android 15+ caps dataSync at ~6h/day and then
         kills the service — mid-shift for a transport meant to run while the user scans. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Self-check diagnostics: detect "no network" as a reason the transport can't connect -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Lets us send the result broadcast back to the dev.fabik.bluetoothhid core app (explicit, Android 11+ visibility). -->
    <queries>
        <package android:name="dev.fabik.bluetoothhid" />
    </queries>

    <application
        android:allowBackup="true"
        android:icon="@android:drawable/ic_dialog_info"
        android:label="@string/app_name"
        android:theme="@style/AppTheme">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Settings entry-point opened by the core app on long-press in the plugin picker -->
            <intent-filter>
                <action android:name="dev.fabik.bluetoothhid.plugin.action.SETTINGS" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Receives scans from the core app. meta-data label is shown in the core's plugin picker.
             NOTE: the label/author meta-data must stay literal strings — the core reads them via
             metaData.getString(), so a @string resource reference would resolve to null there.
             android:permission restricts senders to apps that hold RECEIVE_SCANS. The core
             defines this permission AND must itself request it via uses-permission (defining
             does not grant!) so it can send.
             Other apps must explicitly request it — random apps cannot send fake scans.
             Note: if the core is reinstalled, the plugin must be reinstalled too to restore
             the RECEIVE_SCANS grant (standard Android custom-permission limitation). -->
        <receiver
            android:name=".ScanReceiver"
            android:exported="true"
            android:permission="dev.fabik.bluetoothhid.permission.RECEIVE_SCANS">
            <intent-filter>
                <action android:name="dev.fabik.bluetoothhid.action.BARCODE_SCANNED" />
            </intent-filter>
            <meta-data
                android:name="dev.fabik.bluetoothhid.plugin.label"
                android:value="TCP Transport Plugin" />
            <!-- Short name for space-constrained spots in the core's UI (per-scan result
                 snackbar: "Plugin TCP: sent"). Optional; core falls back to the label above. -->
            <meta-data
                android:name="dev.fabik.bluetoothhid.plugin.shortLabel"
                android:value="TCP" />
            <meta-data
                android:name="dev.fabik.bluetoothhid.plugin.author"
                android:value="zselog" />
        </receiver>

        <!-- Lifecycle + health channel from the core (warm up / release / liveness ping).
             Same permission restriction as ScanReceiver — only RECEIVE_SCANS holders can send. -->
        <receiver
            android:name=".PluginControlReceiver"
            android:exported="true"
            android:permission="dev.fabik.bluetoothhid.permission.RECEIVE_SCANS">
            <intent-filter>
                <action android:name="dev.fabik.bluetoothhid.plugin.action.SET_ENABLED" />
                <action android:name="dev.fabik.bluetoothhid.plugin.action.PING" />
            </intent-filter>
        </receiver>

        <service
            android:name=".TcpService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Persistent local-network TCP transport forwarding barcode scans from the companion scanner app while the user is actively scanning" />
        </service>
    </application>
</manifest>
